generator client {
  provider = "prisma-client-js"
  output   = "../src/db/generated/client"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  name          String?
  passwordHash  String
  role          String     @default("VIEWER")
  lastLoginAt   DateTime?
  lastLoginIp   String?
  failedLogins  Int        @default(0)
  isLockedOut   Boolean    @default(false)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  deletedAt     DateTime?
  createdAudits AuditLog[] @relation("UserAudits")

  @@map("users")
}

model Client {
  id          String      @id @default(cuid())
  name        String
  gst         String?
  email       String?
  phone       String?
  address1    String
  address2    String?
  state       String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  deletedAt   DateTime?
  createdById String?
  updatedById String?
  pinCode     String?
  active      Boolean     @default(true)
  invoices    Invoice[]
  quotations  Quotation[]

  @@index([deletedAt])
  @@index([active])
  @@index([active, deletedAt])
  @@map("clients")
}

model Product {
  id           String    @id @default(cuid())
  sku          String?   @unique
  description  String    @db.Text
  hsn          String?
  gstRate      Decimal   @db.Decimal(5, 2)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  active       Boolean   @default(true)
  notes        String?   @db.Text
  pkgType      String?   @default("BOX")
  purchaseRate Decimal   @default(0.00) @db.Decimal(12, 2)
  sellingRate  Decimal   @default(0.00) @db.Decimal(12, 2)
  unit         String    @default("BOX")
  createdById  String?
  updatedById  String?

  @@index([deletedAt])
  @@index([active])
  @@index([active, deletedAt])
  @@map("products")
}

model Invoice {
  id                    String            @id @default(cuid())
  clientId              String
  sequenceNumber        Int               @unique
  invoiceNo             String            @unique
  date                  DateTime
  dueDate               DateTime?
  gstType               String
  subTotal              Decimal           @db.Decimal(12, 2)
  taxTotal              Decimal           @db.Decimal(12, 2)
  grandTotal            Decimal           @db.Decimal(12, 2)
  amountPaid            Decimal           @default(0.00) @db.Decimal(12, 2)
  status                String            @default("DRAFT")
  ewayBill              String?
  vehicleNo             String?
  dispatchedThrough     String?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  deletedAt             DateTime?
  createdById           String?
  updatedById           String?
  notes                 String?           @db.Text
  billingAddress1       String?
  billingAddress2       String?
  billingGst            String?
  billingName           String?
  billingPhone          String?
  billingPinCode        String?
  billingState          String?
  shippingAddress1      String?
  shippingAddress2      String?
  shippingName          String?
  shippingPinCode       String?
  shippingSameAsBilling Boolean           @default(true)
  shippingState         String?
  lineItems             InvoiceLineItem[]
  client                Client            @relation(fields: [clientId], references: [id])
  payments              Payment[]

  @@index([date])
  @@index([status])
  @@index([clientId, deletedAt])
  @@index([invoiceNo, deletedAt])
  @@index([date, deletedAt])
  @@index([status, deletedAt])
  @@map("invoices")
}

model Payment {
  id         String   @id @default(cuid())
  invoiceId  String
  amount     Decimal  @db.Decimal(12, 2)
  paidAt     DateTime @default(now())
  method     String
  reference  String?
  notes      String?  @db.Text
  recordedBy String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  invoice    Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([paidAt])
  @@map("payments")
}

model Quotation {
  id                    String              @id @default(cuid())
  clientId              String
  sequenceNumber        Int                 @unique
  quotationNo           String              @unique
  date                  DateTime
  validUntil            DateTime?
  gstType               String
  subTotal              Decimal             @db.Decimal(12, 2)
  taxTotal              Decimal             @db.Decimal(12, 2)
  grandTotal            Decimal             @db.Decimal(12, 2)
  status                String              @default("DRAFT")
  convertedInvoiceId    String?
  notes                 String?             @db.Text
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  deletedAt             DateTime?
  createdById           String?
  updatedById           String?
  billingAddress1       String?
  billingAddress2       String?
  billingGst            String?
  billingName           String?
  billingPhone          String?
  billingPinCode        String?
  billingState          String?
  shippingAddress1      String?
  shippingAddress2      String?
  shippingName          String?
  shippingPinCode       String?
  shippingSameAsBilling Boolean             @default(true)
  shippingState         String?
  lineItems             QuotationLineItem[]
  client                Client              @relation(fields: [clientId], references: [id])

  @@index([date])
  @@index([status])
  @@index([clientId], map: "quotations_clientId_fkey")
  @@index([date, deletedAt])
  @@index([status, deletedAt])
  @@map("quotations")
}

model QuotationLineItem {
  id          String    @id @default(cuid())
  quotationId String
  productId   String?
  description String    @db.Text
  hsn         String?
  qty         Int
  rate        Decimal   @db.Decimal(10, 2)
  taxPercent  Decimal   @db.Decimal(5, 2)
  taxAmount   Decimal   @db.Decimal(10, 2)
  totalAmount Decimal   @db.Decimal(12, 2)
  unit        String    @default("NOS")
  pkgCount    Int       @default(0)
  pkgType     String?   @default("BOX")
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  @@index([quotationId])
  @@map("quotation_line_items")
}

model CompanySetting {
  id              String   @id @default(cuid())
  companyName     String   @default("ESSAR ENTERPRISES")
  gstin           String   @default("29AOPPM7487J1ZV")
  pan             String?
  address1        String   @default("SITE NO.9, SEEGAHALLI VILLAGE")
  address2        String?  @default("KR PURAM HOBLI")
  city            String   @default("BANGALORE")
  state           String   @default("Karnataka")
  pincode         String   @default("560049")
  phone           String   @default("+91 85531 85300")
  email           String   @default("essarwater.info@gmail.com")
  website         String?
  bankName        String   @default("FEDERAL BANK")
  bankBranch      String   @default("DOMMASANDRA")
  bankAccountNo   String   @default("21650200003173")
  bankIfsc        String   @default("FDRL0002165")
  bankAccountName String   @default("ESSAR ENTERPRISES")
  invoicePrefix   String   @default("SRB2B")
  quotationPrefix String   @default("SRQUO")
  defaultGstType  String   @default("CGST_SGST")
  currency        String   @default("INR")
  updatedAt       DateTime @updatedAt
  showPkgDetails  Boolean  @default(false)

  @@map("company_settings")
}

model InvoiceLineItem {
  id          String  @id @default(cuid())
  invoiceId   String
  productId   String?
  description String  @db.Text
  hsn         String?
  qty         Int
  rate        Decimal @db.Decimal(10, 2)
  taxPercent  Decimal @db.Decimal(5, 2)
  taxAmount   Decimal @db.Decimal(10, 2)
  totalAmount Decimal @db.Decimal(12, 2)
  unit        String  @default("NOS")
  pkgCount    Int     @default(0)
  pkgType     String? @default("BOX")
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("invoice_line_items")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entityType String
  entityId   String?
  details    String?  @db.LongText
  ipAddress  String?
  createdAt  DateTime @default(now())
  user       User?    @relation("UserAudits", fields: [userId], references: [id])

  @@index([createdAt])
  @@index([userId], map: "audit_logs_userId_fkey")
  @@index([entityType, entityId])
  @@index([action])
  @@map("audit_logs")
}

model Vendor {
  id          String     @id @default(cuid())
  name        String
  gst         String?
  email       String?
  phone       String?
  address1    String
  address2    String?
  state       String
  pinCode     String?
  active      Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?
  createdById String?
  updatedById String?
  purchases   Purchase[]

  @@index([deletedAt])
  @@index([active])
  @@map("vendors")
}

model Purchase {
  id             String             @id @default(cuid())
  vendorId       String
  sequenceNumber Int                @unique
  purchaseNo     String             @unique
  date           DateTime
  gstType        String             @default("CGST_SGST")
  subTotal       Decimal            @db.Decimal(12, 2)
  taxTotal       Decimal            @db.Decimal(12, 2)
  grandTotal     Decimal            @db.Decimal(12, 2)
  status         String             @default("RECEIVED")
  ewayBill       String?
  ewayBillUrl    String?
  vehicleNo      String?
  notes          String?            @db.Text
  createdById    String?
  updatedById    String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  deletedAt      DateTime?
  lineItems      PurchaseLineItem[]
  vendor         Vendor             @relation(fields: [vendorId], references: [id])

  @@index([date])
  @@index([status])
  @@index([vendorId, deletedAt])
  @@index([purchaseNo, deletedAt])
  @@map("purchases")
}

model PurchaseLineItem {
  id          String   @id @default(cuid())
  purchaseId  String
  productId   String?
  description String   @db.Text
  hsn         String?
  qty         Int
  rate        Decimal  @db.Decimal(12, 2)
  taxPercent  Decimal  @db.Decimal(5, 2)
  taxAmount   Decimal  @db.Decimal(12, 2)
  totalAmount Decimal  @db.Decimal(12, 2)
  unit        String   @default("NOS")
  pkgCount    Int      @default(0)
  pkgType     String   @default("BOX")
  purchase    Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  @@index([purchaseId])
  @@map("purchase_line_items")
}
